model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  aksi      String
  entitas   String
  entitasId String?
  perubahan Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entitas, entitasId])
  @@index([createdAt])
}
